          {
            "name": "type",
            "in": "query",
            "description": "Filter by train type (case-insensitive)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zone",
            "in": "query",
            "description": "Filter by railway zone (case-insensitive)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
