    "/api/v1/trains/{trainNumber}": {
      "get": {
        "tags": [
          "Trains"
        ],
        "summary": "Get Comprehensive Train Data (Static + Live)",
        "description": "**This is the primary and most important endpoint for fetching detailed train information.**\n\nIt provides a comprehensive object containing static details (like schedule, route, running days) and can optionally include real-time live tracking data.\n\n### Understanding `dataType`\nThis parameter controls the content of the response:\n- `full` (default): Returns the complete `TrainData` object, including static info, route, and live data if available.\n- `static`: Returns only the static `TrainData` (train info and route), without making a call for live data. Useful for displaying schedules without needing real-time status.\n- `live`: Returns only the `LiveTrainStatus` object. This is a lightweight option to quickly get the current status of a train without fetching the full static schedule again.\n\n### Understanding `journeyDate`\nThe `journeyDate` (in `YYYY-MM-DD` format) is crucial for identifying a specific instance of a train's run. \n- If you provide a date, the API will fetch the status for that specific journey.\n- If you **do not** provide a date, RailRadar's backend will automatically determine the most relevant journey date. This could be today's date if the train is running, a past date if the train has recently arrived, or the next upcoming run date.\n",
        "operationId": "getTrainData",
        "parameters": [
          {
            "name": "trainNumber",
            "in": "path",
            "required": true,
            "description": "5-digit train number",
            "schema": {
              "type": "string",
              "pattern": "^\\d{5}"
            }
          },
          {
            "name": "journeyDate",
            "in": "query",
            "description": "Journey start date in YYYY-MM-DD format. If omitted, the API will auto-detect the most relevant journey.",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dataType",
            "in": "query",
            "description": "Specifies the type of data to retrieve (`full`, `static`, or `live`).",
            "schema": {
              "type": "string",
              "enum": [
                "full",
                "static",
                "live"
              ],
              "default": "full"
            }
          },
          {
            "name": "dataProvider",
            "in": "query",
            "description": "Data provider for live information.",
            "schema": {
              "$ref": "#/components/schemas/DataProvider"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "description": "User ID for tracking purposes (optional).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Train data retrieved successfully. The response will be either a `TrainData` object or a `LiveTrainStatus` object depending on the `dataType` parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrainDataResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
