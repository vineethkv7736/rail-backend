{
  "openapi": "3.1.0",
  "info": {
    "title": "RailRadar API",
    "description": "**Live train tracking and railway information API for Indian Railways**\n\nAccess comprehensive train and station data including:\n- Real-time train tracking and status\n- Complete train schedules and routes\n- Station information and live boards\n- Train search and discovery\n\n**Disclaimer on Data Sources**\n\nPlease be advised that RailRadar is not affiliated with NTES or any official government body. Our data is aggregated from a variety of sources to provide the most accurate and up-to-date information possible. This includes, but is not limited to:\n- Constant web scraping of third-party railway information websites.\n- Advanced error recovery and data cross-verification systems.\n- Utilization of Google Maps and Google Search snippets for train positioning and status validation.\n- Manual updates and corrections to our database by our team.\n\nWhile we strive for accuracy, the data is provided \"as is\" without any warranty.\n",
    "version": "1.0.0",
    "contact": {
      "name": "RailRadar Support",
      "url": "https://railradar.in"
    }
  },
  "servers": [
    {
      "url": "https://railradar.in",
      "description": "Normal API Server"
    },
    {
      "url": "https://api.railradar.in",
      "description": "Production API Server"
    },
    {
      "url": "http://localhost:3001",
      "description": "Development API Server"
    }
  ],
